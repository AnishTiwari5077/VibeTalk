<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- LaunchTheme: shown while the Flutter engine is starting.
         Using Theme.Black ensures the background is dark for both
         call-on-lock-screen launches AND normal launches, eliminating
         the white flash before IncomingCallScreen renders. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <!-- Remove the activity slide-in animation that causes the left-right
             "shake" effect when fullScreenIntent fires on the lock screen. -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the process has started.
         This theme determines the color of the Android Window while your
         Flutter UI initializes, as well as behind your Flutter UI while its
         running.

         This Theme is only used starting with V2 of Flutter's Android embedding. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
        <!-- Remove activity transition animations on this theme too so there
             is no slide when Android switches from LaunchTheme to NormalTheme. -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>
</resources>
