<?xml version="1.0" encoding="utf-8"?>
<!-- Launch background for call notifications on lock screen.
     Black matches the dark IncomingCallScreen — prevents the white-to-dark
     flash when the app wakes from killed state due to fullScreenIntent. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/black" />
</layer-list>
