{
  "_instructions": [
    "1. Copy this file: cp dart_defines.json.example dart_defines.json",
    "2. Fill in your real values below (dart_defines.json is gitignored)",
    "3. Run app:     flutter run --dart-define-from-file dart_defines.json",
    "4. Build APK:   flutter build apk --release --dart-define-from-file dart_defines.json",
    "5. Build AAB:   flutter build appbundle --release --dart-define-from-file dart_defines.json"
  ],
  "CLOUDINARY_CLOUD_NAME": "your_cloudinary_cloud_name",
  "CLOUDINARY_UPLOAD_PRESET": "your_upload_preset",
  "ZEGO_APP_ID": 0,
  "ZEGO_APP_SIGN": "your_zego_app_sign",
  "NOTIFICATION_BACKEND_URL": "http://192.168.x.x:3000",
  "FIREBASE_PROJECT_ID": "your_firebase_project_id",
  "FIREBASE_MESSAGING_SENDER_ID": "your_sender_id",
  "FIREBASE_DATABASE_URL": "https://your-project-default-rtdb.firebaseio.com",
  "FIREBASE_STORAGE_BUCKET": "your-project.firebasestorage.app",
  "FIREBASE_ANDROID_API_KEY": "your_android_api_key",
  "FIREBASE_ANDROID_APP_ID": "1:your_sender_id:android:your_app_id",
  "FIREBASE_IOS_API_KEY": "your_ios_api_key",
  "FIREBASE_IOS_APP_ID": "1:your_sender_id:ios:your_app_id",
  "FIREBASE_IOS_BUNDLE_ID": "com.example.myApp"
}

